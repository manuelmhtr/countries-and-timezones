{
  "compilerOptions": {
    "target": "es2017",
    "lib": [ "es2017" ],
    "module": "esnext",
    "moduleResolution": "node16",
    "types": [ "chai", "mocha" ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
